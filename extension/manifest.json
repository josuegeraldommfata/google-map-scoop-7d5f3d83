{
  "manifest_version": 3,
  "name": "Leads Hunter Auto Sender",
  "version": "1.0.0",
  "description": "Envia automaticamente a mensagem pre-preenchida no WhatsApp Web quando o Leads Hunter recarrega a aba.",
  "permissions": ["storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": { "default_popup": "popup.html", "default_icon": "icon.png" },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
